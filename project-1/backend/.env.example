# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/delivery_documents?schema=public"

# JWT (generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-random-string-here
JWT_EXPIRES_IN=24h

# File upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:5173

# Admin (used by seed script only)
ADMIN_EMAIL=admin@delivery.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=System Admin
