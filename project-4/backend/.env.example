# Server
PORT=5001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/quotebuilder?schema=public"

# JWT
JWT_SECRET=your-super-secret-random-string-here
JWT_EXPIRES_IN=24h

# File upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:5177

# Admin
ADMIN_EMAIL=admin@quotebuilder.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=System Admin

# Business Info
BUSINESS_NAME=Your Business Ltd
BUSINESS_EMAIL=hello@yourbusiness.com
BUSINESS_PHONE=07700 900000
BUSINESS_ADDRESS=123 High Street, London, SW1A 1AA
VAT_NUMBER=GB123456789
