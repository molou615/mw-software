# Server
PORT=5000
NODE_ENV=production

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/delivery_documents?schema=public"

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h

# File upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# CORS
CORS_ORIGIN=http://localhost:5173
